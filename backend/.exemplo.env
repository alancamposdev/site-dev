# Porta do servidor
PORT=3000

# URL de conexão com o MongoDB Atlas
# Formato: mongodb+srv://usuario:senha@cluster.mongodb.net/nomebanco?retryWrites=true&w=majority&appName=NomeCluster
DATABASE_URL="mongodb+srv://usuario:senha@cluster.mongodb.net/nomebanco?retryWrites=true&w=majority&appName=Cluster0"

# Chave secreta para assinar os tokens JWT
JWT_SECRET="sua_chave_secreta_aqui"